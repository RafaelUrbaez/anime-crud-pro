@model AnimeCrudPro.Anime

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Título | Panel de Gestión</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-warning py-3">
                        <h4 class="mb-0 text-center text-dark">📝 Modificar Información</h4>
                    </div>
                    <div class="card-body p-4">
                        <form action="/Anime/Edit" method="post">
                            
                            <input type="hidden" name="Id" value="@Model.Id" />

                            <div class="mb-4">
                                <label class="form-label fw-bold text-secondary">Título Actualizado</label>
                                <input type="text" name="Titulo" class="form-control form-control-lg" value="@Model.Titulo" required />
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-secondary">Episodios</label>
                                <input type="number" name="Episodios" class="form-control form-control-lg" value="@Model.Episodios" required />
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-warning btn-lg shadow-sm fw-bold">Guardar Cambios</button>
                                <a href="/Anime/Index" class="btn btn-link text-decoration-none text-muted text-center">Cancelar y Salir</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>